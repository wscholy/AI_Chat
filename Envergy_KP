# ──────────────────────────────────────────────
# 에너지 계산 함수
# ──────────────────────────────────────────────
def calc_kinetic_energy(mass: float, velocity: float) -> float:
    """운동에너지 = 0.5 * m * v^2"""
    return 0.5 * mass * velocity ** 2

def calc_potential_energy(mass: float, height: float, g: float = 9.8) -> float:
    """위치에너지 = m * g * h"""
    return mass * g * height

def simulate_free_fall(mass: float, initial_height: float, g: float = 9.8) -> dict:
    """자유낙하 시뮬레이션 데이터 생성"""
    # 떨어지는 시간
    total_time = math.sqrt(2 * initial_height / g)
    time_steps = np.linspace(0, total_time, 200)

    heights, velocities, ke_list, pe_list, te_list = [], [], [], [], []

    for t in time_steps:
        h = initial_height - 0.5 * g * t**2
        h = max(0, h)
        v = g * t if h > 0 else math.sqrt(2 * g * initial_height)
        ke = calc_kinetic_energy(mass, v)
        pe = calc_potential_energy(mass, h, g)
        te = ke + pe

        heights.append(round(h, 3))
        velocities.append(round(v, 3))
        ke_list.append(round(ke, 3))
        pe_list.append(round(pe, 3))
        te_list.append(round(te, 3))

    return {
        "time": time_steps.tolist(),
        "height": heights,
        "velocity": velocities,
        "KE": ke_list,
        "PE": pe_list,
        "TE": te_list,
        "total_time": round(total_time, 3),
        "max_velocity": round(math.sqrt(2 * g * initial_height), 3),
        "initial_PE": round(calc_potential_energy(mass, initial_height, g), 3),
    }

def simulate_pendulum(mass: float, length: float, angle_deg: float, g: float = 9.8) -> dict:
    """진자 시뮬레이션 데이터 생성"""
    angle_rad = math.radians(angle_deg)
    max_height = length * (1 - math.cos(angle_rad))
    period = 2 * math.pi * math.sqrt(length / g)
    time_steps = np.linspace(0, 2 * period, 400)

    angles, heights, velocities, ke_list, pe_list = [], [], [], [], []
    omega = math.sqrt(g / length)

    for t in time_steps:
        theta = angle_rad * math.cos(omega * t)
        h = length * (1 - math.cos(theta))
        v = math.sqrt(max(0, 2 * g * (max_height - h)))
        ke = calc_kinetic_energy(mass, v)
        pe = calc_potential_energy(mass, h, g)

        angles.append(round(math.degrees(theta), 3))
        heights.append(round(h, 4))
        velocities.append(round(v, 4))
        ke_list.append(round(ke, 4))
        pe_list.append(round(pe, 4))

    return {
        "time": time_steps.tolist(),
        "angle": angles,
        "height": heights,
        "velocity": velocities,
        "KE": ke_list,
        "PE": pe_list,
        "TE": [round(ke + pe, 4) for ke, pe in zip(ke_list, pe_list)],
        "period": round(period, 3),
        "max_height": round(max_height, 4),
        "max_velocity": round(math.sqrt(2 * g * max_height), 4),
        "initial_PE": round(calc_potential_energy(mass, max_height, g), 4),
    }

def simulate_roller_coaster(mass: float, heights_list: list, g: float = 9.8) -> dict:
    """롤러코스터 시뮬레이션 - 여러 지점의 에너지 계산"""
    max_h = max(heights_list)
    total_energy = calc_potential_energy(mass, max_h, g)
    results = []

    for i, h in enumerate(heights_list):
        pe = calc_potential_energy(mass, h, g)
        ke = total_energy - pe
        ke = max(0, ke)
        v = math.sqrt(2 * ke / mass) if ke > 0 else 0
        results.append({
            "point": f"지점 {i+1}",
            "height": h,
            "PE": round(pe, 2),
            "KE": round(ke, 2),
            "TE": round(pe + ke, 2),
            "velocity": round(v, 2),
        })
    return results

