def plot_energy_chart(sim_data: dict, title: str = "에너지 변환 그래프") -> go.Figure:
    """에너지 변화 그래프"""
    fig = make_subplots(
        rows=2, cols=2,
        subplot_titles=("높이 변화", "속도 변화", "에너지 분포 (애니메이션)", "에너지 전환"),
        specs=[[{"type": "scatter"}, {"type": "scatter"}],
               [{"type": "scatter"}, {"type": "scatter"}]]
    )

    t = sim_data["time"]
    colors = {"KE": "#ff6b6b", "PE": "#4ecdc4", "TE": "#ffd93d"}

    # 높이 변화
    fig.add_trace(go.Scatter(
        x=t, y=sim_data["height"],
        name="높이(m)", line=dict(color="#a8b8ff", width=2),
        showlegend=True
    ), row=1, col=1)

    # 속도 변화
    fig.add_trace(go.Scatter(
        x=t, y=sim_data["velocity"],
        name="속도(m/s)", line=dict(color="#ff9f43", width=2),
        showlegend=True
    ), row=1, col=2)

    # KE, PE, TE 에너지 전환
    for key, color in colors.items():
        label = {"KE": "운동에너지", "PE": "위치에너지", "TE": "역학적에너지(합)"}[key]
        fig.add_trace(go.Scatter(
            x=t, y=sim_data[key],
            name=label, line=dict(color=color, width=2,
                                  dash="dot" if key == "TE" else "solid"),
            showlegend=True
        ), row=2, col=2)

    # 에너지 분포 (특정 시점)
    mid_idx = len(t) // 2
    fig.add_trace(go.Bar(
        x=["운동에너지", "위치에너지"],
        y=[sim_data["KE"][mid_idx], sim_data["PE"][mid_idx]],
        marker_color=["#ff6b6b", "#4ecdc4"],
        showlegend=False,
        name="중간 지점"
    ), row=2, col=1)

    fig.update_layout(
        title=dict(text=title, font=dict(color="white", size=16)),
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(255,255,255,0.03)",
        font=dict(color="#c0c0c0"),
        legend=dict(
            bgcolor="rgba(255,255,255,0.05)",
            bordercolor="rgba(255,255,255,0.2)",
            borderwidth=1
        ),
        height=500,
    )
    fig.update_xaxes(gridcolor="rgba(255,255,255,0.05)", zeroline=False)
    fig.update_yaxes(gridcolor="rgba(255,255,255,0.05)", zeroline=False)

    return fig

def plot_roller_coaster(rc_data: list, heights_list: list) -> go.Figure:
    """롤러코스터 에너지 그래프"""
    points = [d["point"] for d in rc_data]
    hs = [d["height"] for d in rc_data]
    kes = [d["KE"] for d in rc_data]
    pes = [d["PE"] for d in rc_data]
    vs = [d["velocity"] for d in rc_data]

    fig = make_subplots(
        rows=1, cols=2,
        subplot_titles=("롤러코스터 경로", "지점별 에너지"),
        specs=[[{"type": "scatter"}, {"type": "bar"}]]
    )

    # 경로 + 높이
    x_pos = list(range(len(hs)))
    fig.add_trace(go.Scatter(
        x=x_pos, y=hs,
        fill="tozeroy",
        fillcolor="rgba(102,126,234,0.2)",
        line=dict(color="#667eea", width=3),
        mode="lines+markers+text",
        text=[f"v={v}m/s" for v in vs],
        textposition="top center",
        textfont=dict(size=9, color="#ffd93d"),
        name="높이(m)"
    ), row=1, col=1)

    # 스택형 바 차트
    fig.add_trace(go.Bar(
        x=points, y=pes,
        name="위치에너지", marker_color="#4ecdc4"
    ), row=1, col=2)
    fig.add_trace(go.Bar(
        x=points, y=kes,
        name="운동에너지", marker_color="#ff6b6b"
    ), row=1, col=2)

    fig.update_layout(
        barmode="stack",
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(255,255,255,0.03)",
        font=dict(color="#c0c0c0"),
        title=dict(text="🎢 롤러코스터 에너지 전환", font=dict(color="white", size=16)),
        legend=dict(bgcolor="rgba(255,255,255,0.05)", bordercolor="rgba(255,255,255,0.2)"),
        height=400,
    )
    fig.update_xaxes(gridcolor="rgba(255,255,255,0.05)")
    fig.update_yaxes(gridcolor="rgba(255,255,255,0.05)")
    return fig

