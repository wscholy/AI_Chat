with tab2:
    st.markdown("### 📊 에너지 전환 시뮬레이션")

    if run_sim or True:  # 기본값으로 시뮬레이션 표시
        # ── 자유낙하 ──
        if st.session_state.sim_type == "자유낙하":
            if run_sim:
                h_val = init_height
            else:
                h_val = 20.0

            try:
                sim = simulate_free_fall(mass, h_val, g)
            except Exception:
                sim = simulate_free_fall(1.0, 20.0, 9.8)

            # 메트릭
            m1, m2, m3, m4 = st.columns(4)
            m1.metric("초기 위치에너지", f"{sim['initial_PE']:.2f} J",
                      help="PE = mgh")
            m2.metric("최대 속도 (바닥)", f"{sim['max_velocity']:.2f} m/s",
                      help="v = √(2gh)")
            m3.metric("최대 운동에너지", f"{sim['initial_PE']:.2f} J",
                      help="에너지 보존: KE_max = PE_initial")
            m4.metric("낙하 시간", f"{sim['total_time']:.2f} s",
                      help="t = √(2h/g)")

            st.markdown("""
            <div class='formula-box'>
                🔽 자유낙하 에너지 전환<br>
                시작: PE = mgh,  KE = 0<br>
                중간: PE ↓ 감소,  KE ↑ 증가<br>
                바닥: PE = 0,  KE = mgh  (역학적 에너지 보존!)
            </div>
            """, unsafe_allow_html=True)

            fig = plot_energy_chart(sim, f"🔽 자유낙하 에너지 전환 (높이={h_val}m, 질량={mass}kg)")
            st.plotly_chart(fig, use_container_width=True)

            # 세부 데이터 표
            with st.expander("📋 시뮬레이션 상세 데이터 보기"):
                step = max(1, len(sim["time"]) // 10)
                data_rows = []
                for i in range(0, len(sim["time"]), step):
                    data_rows.append({
                        "시간(s)": round(sim["time"][i], 3),
                        "높이(m)": round(sim["height"][i], 3),
                        "속도(m/s)": round(sim["velocity"][i], 3),
                        "운동에너지(J)": round(sim["KE"][i], 3),
                        "위치에너지(J)": round(sim["PE"][i], 3),
                        "역학적에너지(J)": round(sim["TE"][i], 3),
                    })
                st.dataframe(data_rows, use_container_width=True)

        # ── 진자 운동 ──
        elif st.session_state.sim_type == "진자 운동":
            try:
                p_len = pendulum_len
                p_ang = swing_angle
            except Exception:
                p_len, p_ang = 2.0, 30.0

            sim = simulate_pendulum(mass, p_len, p_ang, g)

            m1, m2, m3, m4 = st.columns(4)
            m1.metric("주기", f"{sim['period']:.3f} s", help="T = 2π√(L/g)")
            m2.metric("최대 높이", f"{sim['max_height']:.4f} m")
            m3.metric("최대 속도", f"{sim['max_velocity']:.4f} m/s")
            m4.metric("초기 위치에너지", f"{sim['initial_PE']:.4f} J")

            st.markdown("""
            <div class='formula-box'>
                🌀 진자 에너지 전환<br>
                최고점: PE 최대, KE = 0  (잠깐 멈춤!)<br>
                최저점: PE = 0, KE 최대  (가장 빠름!)<br>
                주기: T = 2π × √(L/g) → 질량과 무관!
            </div>
            """, unsafe_allow_html=True)

            fig = plot_energy_chart(sim, f"🌀 진자 운동 에너지 전환 (길이={p_len}m, 각도={p_ang}°)")
            st.plotly_chart(fig, use_container_width=True)

            # 각도 그래프 추가
            fig2 = go.Figure()
            fig2.add_trace(go.Scatter(
                x=sim["time"], y=sim["angle"],
                line=dict(color="#a8b8ff", width=2), name="각도(°)"
            ))
            fig2.update_layout(
                title="진자 각도 변화",
                paper_bgcolor="rgba(0,0,0,0)",
                plot_bgcolor="rgba(255,255,255,0.03)",
                font=dict(color="#c0c0c0"),
                height=250,
                xaxis_title="시간(s)", yaxis_title="각도(°)"
            )
            fig2.update_xaxes(gridcolor="rgba(255,255,255,0.05)")
            fig2.update_yaxes(gridcolor="rgba(255,255,255,0.05)")
            st.plotly_chart(fig2, use_container_width=True)

        # ── 롤러코스터 ──
        else:
            try:
                rc_heights = [h1, h2, h3, h4, h5]
            except Exception:
                rc_heights = [40.0, 10.0, 30.0, 5.0, 15.0]

            rc_data = simulate_roller_coaster(mass, rc_heights, g)
            fig = plot_roller_coaster(rc_data, rc_heights)
            st.plotly_chart(fig, use_container_width=True)

            # 지점별 상세
            st.markdown("#### 📋 각 지점 에너지 상세")
            cols = st.columns(len(rc_data))
            for i, (col, d) in enumerate(zip(cols, rc_data)):
                with col:
                    st.markdown(f"""
                    <div class='energy-card' style='text-align:center;'>
                        <b>{d['point']}</b><br>
                        📏 {d['height']}m<br>
                        🔵 PE: {d['PE']:.1f}J<br>
                        🔴 KE: {d['KE']:.1f}J<br>
                        🟡 TE: {d['TE']:.1f}J<br>
                        ⚡ {d['velocity']:.1f}m/s
                    </div>
                    """, unsafe_allow_html=True)

            st.markdown("""
            <div class='formula-box'>
                🎢 롤러코스터 에너지 보존<br>
                높은 곳 → PE 크고 KE 작음 (느림)<br>
                낮은 곳 → PE 작고 KE 큼  (빠름)<br>
                어느 지점이든 PE + KE = 일정!
            </div>
            """, unsafe_allow_html=True)

